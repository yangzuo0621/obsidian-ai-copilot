{
  "name": "obsidian-ai-copilot",
  "version": "0.0.1",
  "description": "AI copilot for Obsidian notes.",
  "main": "main.js",
  "scripts": {
    "build": "npm run typecheck && node esbuild.config.mjs production",
    "deploy:test": "npm run build && node scripts/deploy-test-plugin.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "npm run format:check && npm run lint && npm run build && npm run test",
    "dev": "node esbuild.config.mjs"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "ai",
    "copilot"
  ],
  "author": "yangzuo0621",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "builtin-modules": "^5.3.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "obsidian": "^1.13.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
